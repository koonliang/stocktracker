# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for all text files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf

# Maven wrapper shell script (no extension) — must stay LF so it runs in
# Linux containers (e.g. the backend Docker build).
mvnw text eol=lf

# Force CRLF for Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
