# Homelab SIT deployment inputs. Copy to scripts/.env on the homelab machine and
# keep the real file out of git.

APP_HOST=192.168.100.101
DB_HOST=192.168.100.102
DB_PORT=3306
DB_NAME=stocktracker
DB_USERNAME=stocktracker
DB_PASSWORD=change-me
PUBLIC_BASE_URL=https://example.com
DEPLOY_USER=deploy
SERVICE_NAME=stocktracker-backend-sit

# Optional overrides
# DEPLOY_DIR=/opt/stocktracker/sit
# REMOTE_LOG_FILE=/var/log/stocktracker-sit.log
# SERVICE_NAME may be bare or include the .service suffix. The deploy script
# will upload/update the unit file on the app host and restart it via sudo.
# STOCKTRACKER_MARKETDATA_PROVIDER=yahoo
# STOCKTRACKER_FX_PROVIDER=frankfurter
# SIT_AUTH_MODE=dev
# SIT_DEV_BOOTSTRAP_ENABLED=false
# SIT_SCHEDULER_ENABLED=false
# NONPROD_GOOGLE_CLIENT_ID=
# NONPROD_GOOGLE_CLIENT_SECRET=
# NONPROD_FACEBOOK_CLIENT_ID=
# NONPROD_FACEBOOK_CLIENT_SECRET=
# NONPROD_SOCIAL_REDIRECT_URI=https://example.com/auth/callback
