VITE_API_BASE_URL=http://localhost:8080/api

# Auth strategy: `dev` (default) drives the backend /api/auth/* flows; `cognito`
# uses the Cognito Hosted UI. Production builds set `cognito` (see .github/workflows/cd.yml).
# VITE_AUTH_MODE=cognito
# VITE_COGNITO_DOMAIN=stocktracker-production-auth.auth.ap-southeast-1.amazoncognito.com
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_LOGOUT_URI=http://localhost:5173/signed-out
# Set these for non-production Google/Facebook sign-in in `dev` auth mode.
VITE_NONPROD_GOOGLE_AUTH_URL=
VITE_NONPROD_FACEBOOK_AUTH_URL=
VITE_NONPROD_SOCIAL_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_ENABLE_VERCEL_ANALYTICS=false
VITE_ENABLE_VERCEL_SPEED_INSIGHTS=false
